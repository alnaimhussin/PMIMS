function renderDTR(data) {
    const tbody = document.getElementById('dtrBody');
    tbody.innerHTML = '';
    
    let totalHours = 0;
    let totalLate = 0;
    let daysPresent = 0;
    
    data.forEach(record => {
        const row = document.createElement('tr');
        
        // Apply styling based on record type
        if (record.isWeekend) {
            row.className = 'table-secondary text-muted';
        } else if (record.remarks === 'Absent') {
            row.className = 'table-danger';
        } else if (record.remarks.includes('Late') || record.remarks === 'Undertime') {
            row.className = 'table-warning';
        } else if (record.hours > 0 && record.hours < 8) {
            row.className = 'table-info';
        }
        
        if (record.hours > 0) {
            totalHours += record.hours;
            daysPresent++;
        }
        totalLate += record.late;
        
        row.innerHTML = `
            <td class="font-weight-bold">${record.day}</td>
            <td>${record.amIn || ''}</td>
            <td>${record.amOut || ''}</td>
            <td>${record.pmIn || ''}</td>
            <td>${record.pmOut || ''}</td>
            <td class="font-weight-bold ${record.hours < 8 && record.hours > 0 ? 'text-warning' : 'text-success'}">
                ${record.hours > 0 ? record.hours.toFixed(2) : '-'}
            </td>
            <td class="${record.late > 0 ? 'text-danger font-weight-bold' : ''}">
                ${record.late > 0 ? record.late : '-'}
            </td>
            <td class="font-italic">${record.remarks}</td>
        `;
        
        tbody.appendChild(row);
    });
    
    // Update totals
    document.getElementById('totalHours').textContent = totalHours.toFixed(2);
    document.getElementById('daysPresent').textContent = daysPresent;
    document.getElementById('footerTotalHours').textContent = totalHours.toFixed(2);
    document.getElementById('footerTotalLate').textContent = totalLate;
}

function updateHeaderInfo(month, year) {
    const monthNames = ["", "January", "February", "March", "April", "May", "June",
                       "July", "August", "September", "October", "November", "December"];
    const monthYear = monthNames[month] + " " + year;
    document.getElementById('dtrMonthYear').textContent = monthYear;
    document.getElementById('dtrPeriod').textContent = monthYear;
}

